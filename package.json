{
  "name": "insightaicamp",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:landing",
    "dev:landing": "npm run dev -w @insightaicamp/landing",
    "dev:pipeline": "npm run dev -w @insightaicamp/videopipeline",
    "dev:all": "concurrently \"npm run dev:landing\" \"npm run dev:pipeline\"",
    "build": "npm run build:packages && npm run build:apps",
    "build:packages": "npm run build -w packages/*",
    "build:apps": "npm run build -w apps/*",
    "build:landing": "npm run build -w @insightaicamp/landing",
    "build:pipeline": "npm run build -w @insightaicamp/videopipeline",
    "lint": "npm run lint -w apps/* -w packages/*",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules",
    "install:all": "npm install",
    "pipeline:start": "npm run start -w @insightaicamp/videopipeline",
    "pipeline:worker": "npm run worker -w @insightaicamp/videopipeline",
    "remotion:studio": "npm run remotion:studio -w @insightaicamp/landing"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}